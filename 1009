#include <stdio.h>
#include <math.h>

int main()
{
 char n[50];
 double salario, vendas_mes, salario_comissao, salario_total;
 
 scanf("%s", n);
 scanf("%lf", &salario);
 scanf("%lf", &vendas_mes);
 
 salario_comissao = vendas_mes*15/100;
 salario_total = salario_comissao + salario;
 
 printf("TOTAL = R$ %.2lf\n", salario_total);
 	return 0;
}
